# Google Workspace domain to check actor membership against.
# e.g. "example.edu"
GOOGLE_DIRECTORY_WORKSPACE_DOMAIN=example.edu

# Path to the service account key JSON file. Alternatively, set
# GOOGLE_DIRECTORY_SERVICE_ACCOUNT_KEY_JSON to the raw JSON string.
GOOGLE_DIRECTORY_SERVICE_ACCOUNT_KEY_FILE=/etc/hlao/directory-sa.json

# Admin email in the workspace to impersonate. Domain-wide delegation
# must be authorized for the service account with the
# admin.directory.user.readonly scope for this admin.
GOOGLE_DIRECTORY_ADMIN_EMAIL=admin@example.edu

# Optional: cache TTL for user existence lookups in milliseconds.
# Default 60000 (1 minute).
# GOOGLE_DIRECTORY_CACHE_TTL_MS=60000
