# Google OAuth 2.0 client ID that the ID token's `aud` claim must match.
# Get this from Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client IDs.
GOOGLE_OIDC_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional Workspace hosted-domain check. When set, the token's `hd`
# claim must equal this exactly. Enforces "only users at example.edu
# may approve reviews."
# GOOGLE_OIDC_HOSTED_DOMAIN=example.edu

# Optional explicit allowlist. Comma-separated email addresses. When
# set, verifyToken enforces membership as an additional check on top
# of the crypto + audience + hosted-domain validation.
# GOOGLE_OIDC_ALLOWED_ACTOR_IDS=alice@example.edu,bob@example.edu
