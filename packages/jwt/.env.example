# Generic JWT verifier configuration.

# Expected issuer claim (iss). Required. e.g. https://auth.example.com/
JWT_ISSUER=https://auth.example.com/

# Expected audience claim (aud). Required. Match your API's registered aud.
JWT_AUDIENCE=hlao-review-api

# JWKS URI. Set this OR JWT_PUBLIC_KEY_PEM (below), not both.
# Example: https://auth.example.com/.well-known/jwks.json
# JWT_JWKS_URI=

# Static PEM public key (single-key deployments). Use this OR JWT_JWKS_URI.
# Multiline: base64-encode or replace newlines with literal \n if your env
# tooling requires it, then decode before passing to createJwtVerifier.
# JWT_PUBLIC_KEY_PEM=

# Claim to extract as the actor id. Default 'sub'. Common alternatives:
# 'email', 'preferred_username', 'upn'.
# JWT_ACTOR_CLAIM=sub

# Optional allowlist of actor ids.
# JWT_ALLOWED_ACTOR_IDS=alice@example.com,bob@example.com
