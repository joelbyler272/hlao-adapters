# Google OAuth 2.0 client credentials from Google Cloud Console →
# APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application).
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Absolute redirect URI registered in Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.example.com/auth/google/callback

# Optional: enforce this Workspace domain via the id_token hd claim.
# GOOGLE_OAUTH_HOSTED_DOMAIN=example.edu

# Optional: explicit allowlist. Comma-separated email addresses.
# GOOGLE_OAUTH_ALLOWED_ACTOR_IDS=alice@example.edu,bob@example.edu

# HMAC secret for signing state parameters and session envelopes.
# Must be at least 32 bytes of random data. Generate with:
#   openssl rand -hex 32
GOOGLE_OAUTH_STATE_SIGNING_SECRET=change-me-to-32-plus-bytes-of-random-hex

# Optional: cookie domain. Default: whatever the browser inferred.
# GOOGLE_OAUTH_COOKIE_DOMAIN=.example.com
