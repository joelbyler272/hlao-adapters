# Microsoft Entra ID (Azure AD) OIDC configuration.
#
# ENTRA_TENANT_ID: your tenant id (a GUID) or a directory suffix such as
# 'contoso.onmicrosoft.com'. Get it from the Entra admin portal at:
#   Entra → Overview → Tenant ID.
# Use 'common' only when accepting sign-ins from any Microsoft account.
ENTRA_TENANT_ID=your-tenant-id-here

# ENTRA_CLIENT_ID: application (client) id of the registered app in Entra.
# Portal: App registrations → your app → Overview → Application (client) ID.
ENTRA_CLIENT_ID=your-app-client-id-here

# Optional: allowlist of actor ids the verifier will accept. When set,
# verifyToken rejects any principal not in the list, and verifyActor enforces
# the same set. When unset, verifyActor returns true for any actor id.
# ENTRA_ALLOWED_ACTOR_IDS=alice@contoso.com,bob@contoso.com
