# SAML 2.0 Identity Provider configuration.
#
# SAML_IDP_CERT_PEM: the IdP's X.509 signing certificate in PEM format.
# Get this from your IdP's metadata endpoint or admin console.
# Multiline: base64-encode or replace newlines with literal \n if your
# env loader requires it.
SAML_IDP_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# SAML_EXPECTED_ISSUER: the EntityID / Issuer from the SAML Response.
# Must match exactly. Get it from your IdP's metadata.
SAML_EXPECTED_ISSUER=https://idp.example.com/saml/metadata

# SAML_EXPECTED_AUDIENCE: the SP audience restriction (your application).
# Must match the AudienceRestriction element in the SAML assertion.
SAML_EXPECTED_AUDIENCE=https://your-app.example.com/saml/sp

# Optional: allowlist of actor ids (NameID values).
# SAML_ALLOWED_ACTOR_IDS=alice@example.com,bob@example.com
