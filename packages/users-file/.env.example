# Absolute or relative path to the users JSON file.
# The file must be a JSON object of the shape:
#   { "actors": ["alice@example.com", "bob@example.com", ...] }
# or the extended shape with metadata:
#   { "actors": [{ "id": "alice@example.com", "displayName": "Alice" }, ...] }
USERS_FILE_PATH=./users.json
